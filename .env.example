# Home Lab Manager Configuration
DATABASE_URL=sqlite:///./home_lab_manager.db
APP_TITLE=Home Lab Manager
APP_PORT=8080

# UniFi Integration (Phase 2)
UNIFI_API_KEY=your_api_key_here
UNIFI_BASE_URL=https://192.168.1.1
UNIFI_SITE_ID=your_site_ID
UNIFI_CLOUD_API_KEY=your_cloud_key_here

# Notifications
NOTIFICATIONS_ENABLED=false

# Email (SMTP)
NOTIFY_EMAIL_ENABLED=false
NOTIFY_SMTP_HOST=smtp.gmail.com
NOTIFY_SMTP_PORT=587
NOTIFY_SMTP_USER=
NOTIFY_SMTP_PASS=
NOTIFY_SMTP_FROM=homelab@yourdomain.com
NOTIFY_SMTP_TO=admin@yourdomain.com
NOTIFY_SMTP_TLS=true

# Webhook (generic JSON POST — works with Slack, Discord, etc.)
NOTIFY_WEBHOOK_ENABLED=false
NOTIFY_WEBHOOK_URL=

# Pushover
NOTIFY_PUSHOVER_ENABLED=false
NOTIFY_PUSHOVER_TOKEN=
NOTIFY_PUSHOVER_USER=

# Telegram
NOTIFY_TELEGRAM_ENABLED=false
NOTIFY_TELEGRAM_BOT_TOKEN=
NOTIFY_TELEGRAM_CHAT_ID=
